# BUNKER MINER - Development Environment Configuration
# Copy this file to .env and customize the values for your development environment
#
# SECURITY NOTE: Never commit .env files to version control!
# The .env file contains sensitive credentials for local development only.

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database Settings
POSTGRES_DB=bunker_miner
POSTGRES_USER=bunker_admin
POSTGRES_PASSWORD=secure_dev_password_123

# PostgreSQL Connection Settings (used by applications)
DATABASE_URL=postgresql://bunker_admin:secure_dev_password_123@postgres:5432/bunker_miner
DATABASE_MAX_CONNECTIONS=10
DATABASE_CONNECTION_TIMEOUT=30

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Redis Cache Settings
REDIS_PASSWORD=redis_dev_password_456
REDIS_URL=redis://:redis_dev_password_456@redis:6379/0
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Global Logging Level
RUST_LOG=info
# Options: error, warn, info, debug, trace

# Enable development features
DEVELOPMENT_MODE=true

# API Rate Limiting (requests per minute)
API_RATE_LIMIT=1000

# Session Management
SESSION_SECRET=development_session_secret_key_change_in_production
SESSION_TIMEOUT=3600

# =============================================================================
# STUB SERVICE CONFIGURATION
# =============================================================================

# Pool API Stub Settings
POOL_API_BIND_ADDRESS=0.0.0.0:8080
POOL_DIFFICULTY=300000000000
POOL_FEE_PERCENTAGE=1.0
POOL_MINIMUM_PAYOUT=0.1

# Fleet Controller Stub Settings
FLEET_WS_BIND_ADDRESS=0.0.0.0:8081
FLEET_HTTP_BIND_ADDRESS=0.0.0.0:8082
FLEET_MAX_CONNECTIONS=1000
FLEET_HEARTBEAT_INTERVAL=30

# Coin Daemon Stub Settings
COIN_DAEMON_BIND_ADDRESS=0.0.0.0:18081
COIN_DAEMON_DIFFICULTY=300000000000
COIN_DAEMON_TESTNET=true
COIN_DAEMON_BLOCK_TIME=120

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Settings (for future authentication)
JWT_SECRET=development_jwt_secret_change_in_production
JWT_EXPIRATION=86400

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# =============================================================================
# MONITORING AND OBSERVABILITY
# =============================================================================

# Metrics Collection
ENABLE_METRICS=true
METRICS_PORT=9090

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# =============================================================================
# DEVELOPMENT TOOLS CONFIGURATION
# =============================================================================

# Enable development profiles
COMPOSE_PROFILES=tools

# Hot reload settings (for development)
ENABLE_HOT_RELOAD=true
WATCH_EXTENSIONS=rs,toml,yaml,yml,json

# Debug settings
RUST_BACKTRACE=1
RUST_LOG_STYLE=always

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Docker network settings
DOCKER_NETWORK_SUBNET=172.20.0.0/16

# Service discovery
SERVICE_DISCOVERY_ENABLED=true

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Test database (separate from development)
TEST_DATABASE_URL=postgresql://bunker_admin:secure_dev_password_123@localhost:5432/bunker_miner_test
TEST_REDIS_URL=redis://:redis_dev_password_456@localhost:6379/1

# Test data seeding
SEED_TEST_DATA=true
TEST_MINER_COUNT=5
TEST_POOL_HASHRATE=50000

# =============================================================================
# EXAMPLES AND DOCUMENTATION
# =============================================================================

# Example usage:
# 1. Copy this file to .env: cp .env.example .env
# 2. Customize the values above for your environment
# 3. Start the development environment: docker-compose up -d
# 4. Check service health: docker-compose ps
# 5. View logs: docker-compose logs -f [service-name]
#
# Available services:
# - postgres: PostgreSQL database
# - redis: Redis cache
# - pool-api-stub: Pool management API
# - fleet-controller-stub: WebSocket fleet management
# - coin-daemon-stub: Cryptocurrency daemon JSON-RPC
#
# Service URLs:
# - Pool API: http://localhost:8080
# - Fleet Controller WS: ws://localhost:8081/ws  
# - Fleet Controller HTTP: http://localhost:8082
# - Coin Daemon: http://localhost:18081/json_rpc
# - PostgreSQL: localhost:5432
# - Redis: localhost:6379