# BUNKER MINER - Comprehensive .gitignore
# Covers Rust, C++, Qt, and common development files

#######################
# Rust
#######################

# Generated by Cargo
/target/
**/target/
Cargo.lock
!/Cargo.lock

# Remove Cargo.lock from gitignore if creating an executable, leave commented if creating a library
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

